# PackVote Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/packvote

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# Free tier: 100 emails/day — https://sendgrid.com
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ── AI Providers ──────────────────────────────────────────────────────────────
# Primary: HuggingFace Inference Providers (free tier)
# https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Fallback: Groq free tier (optional — used if HF credits are exhausted)
# https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── Unsplash ──────────────────────────────────────────────────────────────────
# Travel photography — https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
